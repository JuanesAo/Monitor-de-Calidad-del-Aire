{
  "Comment": "Pipeline Calidad del Aire - orquesta los 3 Glue Jobs en secuencia. Si alguno falla, la maquina termina con error.",
  "StartAt": "RawToCurated",
  "States": {
    "RawToCurated": {
      "Type": "Task",
      "Resource": "arn:aws:states:::glue:startJobRun.sync",
      "Parameters": {
        "JobName": "air-quality-raw-to-curated"
      },
      "Next": "BuildFeatures"
    },
    "BuildFeatures": {
      "Type": "Task",
      "Resource": "arn:aws:states:::glue:startJobRun.sync",
      "Parameters": {
        "JobName": "air-quality-build-features"
      },
      "Next": "MLTraining"
    },
    "MLTraining": {
      "Type": "Task",
      "Resource": "arn:aws:states:::glue:startJobRun.sync",
      "Parameters": {
        "JobName": "air-quality-ml-training"
      },
      "End": true
    }
  }
}